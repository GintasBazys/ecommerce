{
    "name": "nuxt-app",
    "private": true,
    "packageManager": "pnpm@10.10.0",
    "type": "module",
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev --host 0.0.0.0",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "type-check": "npx nuxt typecheck"
    },
    "dependencies": {
        "@medusajs/types": "^2.13.6",
        "@nuxt/content": "^3.12.0",
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/image": "^2.0.0",
        "@nuxtjs/sitemap": "^8.0.12",
        "@pinia/nuxt": "^0.11.3",
        "@stripe/stripe-js": "^9.1.0",
        "@unlok-co/nuxt-stripe": "^6.0.2",
        "@vueuse/core": "^14.2.1",
        "@vueuse/integrations": "^14.2.1",
        "better-sqlite3": "^12.8.0",
        "jwt-decode": "^4.0.0",
        "lodash": "^4.18.1",
        "nuxt": "^4.4.2",
        "pdf-lib": "^1.17.1",
        "pinia-plugin-persistedstate": "^4.7.1",
        "querystring-es3": "^0.2.1",
        "swiper": "^12.1.3",
        "vue": "^3.5.32",
        "vuetify-nuxt-module": "0.19.5"
    },
    "devDependencies": {
        "@nuxt/test-utils": "^4.0.2",
        "@types/lodash": "^4.17.24",
        "@types/lodash-es": "^4.17.12",
        "@typescript-eslint/parser": "^8.58.1",
        "@vue/test-utils": "^2.4.6",
        "devalue": "5.7.1",
        "eslint": "^10.2.0",
        "happy-dom": "^20.8.9",
        "prettier": "3.8.2",
        "sass": "1.99.0",
        "sass-loader": "^16.0.7",
        "vitest": "^4.1.4",
        "vue-eslint-parser": "^10.4.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "better-sqlite3"
        ],
        "supportedArchitectures": {
            "os": [
                "current",
                "linux"
            ],
            "cpu": [
                "current",
                "x64",
                "arm64"
            ]
        }
