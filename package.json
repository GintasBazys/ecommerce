        "@pinia/nuxt": "^0.11.3",
        "@sentry/nuxt": "^10.52.0",
        "@stripe/stripe-js": "^9.4.0",
        "@vueuse/core": "^14.3.0",
        "@vueuse/integrations": "^14.3.0",
        "jwt-decode": "^4.0.0",
        "nuxt": "^4.4.4",
        "pinia": "^3.0.4",
        "posthog-js": "^1.372.10",
        "posthog-node": "^5.33.4",
        "querystring-es3": "^0.2.1",
        "vue": "^3.5.34"
